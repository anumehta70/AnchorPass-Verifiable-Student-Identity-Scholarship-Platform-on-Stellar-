# Postgres connection string (Supabase or self-hosted)
DATABASE_URL="postgresql://user:password@localhost:5432/anchorpass?schema=public"

# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Stellar / Soroban
SOROBAN_RPC_URL="https://soroban-testnet.stellar.org"
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
SOROBAN_CONTRACT_ID="REPLACE_WITH_DEPLOYED_CONTRACT_ID"

# IPFS / Pinata
PINATA_JWT="REPLACE_WITH_PINATA_JWT"
PINATA_GATEWAY_URL="https://gateway.pinata.cloud/ipfs"

# Monitoring / Analytics
SENTRY_DSN="REPLACE_WITH_SENTRY_DSN"
POSTHOG_API_KEY="REPLACE_WITH_POSTHOG_KEY"
POSTHOG_HOST="https://app.posthog.com"

# Public app URL, used to build verification links
PUBLIC_APP_URL="http://localhost:5173"
